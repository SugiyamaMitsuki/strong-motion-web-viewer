{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "isolatedModules": false,
    "noEmit": false,
    "noEmitOnError": true,
    "outDir": ".test-dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/analysis/calculus.ts",
    "src/analysis/distance.ts",
    "src/analysis/fft.ts",
    "src/analysis/horizontalVerticalRatio.ts",
    "src/analysis/jmaIntensity.ts",
    "src/analysis/orbit.ts",
    "src/analysis/responseSpectrum.ts",
    "src/analysis/statistics.ts",
    "src/analysis/wavelet.ts",
    "src/parsers/jma.ts",
    "src/export/exportImage.ts",
    "src/utils/file.ts",
    "src/visualization/downsample.ts",
    "src/visualization/journal.ts",
    "src/visualization/waveformGroups.ts",
    "src/visualization/plotGeometry.ts",
    "src/types/waveform.ts"
  ]
}
